<script>
  // Animate meter bars on scroll
  const meters = document.querySelectorAll('.meter-fill');
  const reveals = document.querySelectorAll('.reveal');

  const obs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.classList.add('in');
        if(e.target.classList.contains('meter') ){
          const fill = e.target.querySelector('.meter-fill');
          if(fill) fill.style.width = fill.dataset.w + '%';
        }
        obs.unobserve(e.target);
      }
    });
  },{threshold:0.2});

  reveals.forEach(el=>obs.observe(el));

  // also trigger meter fills nested in reveal
  document.querySelectorAll('.meter.reveal').forEach(el=>obs.observe(el));
</script>

