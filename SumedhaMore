      <div class="hero-ctas">
        <a class="btn btn-primary" href="mailto:moresumedha1121@gmail.com">✉ Email Me</a>
        <a class="btn btn-ghost" href="https://wa.me/918320222893" target="_blank" rel="noopener">WhatsApp</a>
        <a class="btn btn-ghost" href="data:application/pdf;base64," download="Sumedha_More_Resume.pdf">↓ Download Resume</a>
      </div>
    </div>
    <div class="hero-tag reveal">
      <div class="punch"></div>
