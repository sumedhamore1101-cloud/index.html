<header class="hero">
  <div class="wrap hero-grid">
    <div>
      <img class="profile-photo" src="data:image/jpeg;base64," alt="Sumedha More">
      <div class="eyebrow-row">
        <span class="tag">MBA · ICT MUMBAI · 2026</span>
        <span class="tag citrus">FMCG / F&amp;B FOCUS</span>
