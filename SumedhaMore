<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sumedha More — Brand & Marketing Strategist</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1F2A1E;
    --paper:#F6F2E7;
    --paper2:#FBF8F1;
    --citrus:#FF5A2B;
    --leaf:#5C7A3D;
    --gold:#D9A441;
    --charcoal:#232620;
    --muted:#7a7868;
    --line: rgba(35,38,32,0.12);
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--charcoal);
    font-family:'Inter',sans-serif;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,.display{
    font-family:'Bricolage Grotesque',sans-serif;
    font-weight:700;
    letter-spacing:-0.01em;
    color:var(--ink);
    margin:0;
  }
  .mono{font-family:'IBM Plex Mono',monospace;}
  a{color:inherit;text-decoration:none;}
  .wrap{max-width:1080px;margin:0 auto;padding:0 28px;}
  section{padding:96px 0;}
  @media(max-width:640px){ section{padding:64px 0;} }

  /* ---- Tag / label signature element ---- */
  .tag{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-family:'IBM Plex Mono',monospace;
    font-size:12px;
    font-weight:600;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--ink);
    background:var(--paper2);
    border:1px solid var(--line);
    padding:7px 16px 7px 22px;
    clip-path:polygon(14px 0,100% 0,100% 100%,14px 100%,0 50%);
    position:relative;
  }
  .tag::before{
    content:'';
    position:absolute;
    left:6px; top:50%;
    width:4px; height:4px;
    background:var(--ink);
    border-radius:50%;
    transform:translateY(-50%);
  }
  .tag.citrus{color:#fff;background:var(--citrus);border-color:var(--citrus);}
  .tag.citrus::before{background:#fff;}
  .tag.leaf{color:#fff;background:var(--leaf);border-color:var(--leaf);}
  .tag.leaf::before{background:#fff;}

  /* ---- Nav ---- */
  nav{
    position:sticky; top:0; z-index:50;
    background:rgba(246,242,231,0.92);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--line);
  }
  .navrow{display:flex;align-items:center;justify-content:space-between;padding:16px 0;}
  .navrow .name{font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:18px;}
  .navlinks{display:flex;gap:26px;font-size:14px;font-weight:600;}
  .navlinks a{opacity:0.75;transition:opacity .2s, color .2s;}
  .navlinks a:hover{opacity:1;color:var(--citrus);}
  .navcta{
    background:var(--ink);color:var(--paper);
    padding:9px 18px;border-radius:30px;font-size:13px;font-weight:600;
  }
  .mobile-only{display:none;}
  @media(max-width:760px){
    .navlinks{display:none;}
    .navcta{padding:8px 14px;font-size:12px;}
  }

  /* ---- Hero ---- */
  .hero{padding:88px 0 60px;}
  .hero-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:56px;align-items:center;}
  @media(max-width:880px){.hero-grid{grid-template-columns:1fr;}}
  .profile-photo{
    width:88px;height:88px;border-radius:50%;object-fit:cover;
    border:3px solid var(--citrus);box-shadow:0 6px 16px rgba(31,42,30,0.18);
    margin-bottom:22px;display:block;
  }
  .eyebrow-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:22px;}
  .hero h1{font-size:56px;line-height:1.02;}
  @media(max-width:640px){.hero h1{font-size:38px;}}
  .hero .role{font-size:20px;color:var(--leaf);font-weight:600;margin-top:14px;font-family:'Bricolage Grotesque',sans-serif;}
  .hero p.lead{margin-top:20px;font-size:16.5px;color:var(--charcoal);max-width:540px;}
  .hero-ctas{display:flex;gap:14px;margin-top:30px;flex-wrap:wrap;}
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    padding:13px 24px;border-radius:30px;font-weight:600;font-size:14px;
    transition:transform .2s, box-shadow .2s;
  }
  .btn-primary{background:var(--citrus);color:#fff;}
  .btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(255,90,43,0.25);}
  .btn-ghost{border:1.5px solid var(--ink);color:var(--ink);}
  .btn-ghost:hover{background:var(--ink);color:var(--paper);}

  /* hero swing-tag visual */
  .hero-tag{
    background:var(--ink);
    color:var(--paper);
    border-radius:20px;
    padding:34px 30px;
    position:relative;
    box-shadow:0 24px 50px rgba(31,42,30,0.25);
  }
  .hero-tag::after{
    content:'';
    position:absolute; top:24px; right:24px;
    width:14px;height:14px;border-radius:50%;
    background:var(--paper); opacity:.15;
  }
  .hero-tag .punch{
    width:34px;height:34px;border-radius:50%;
    border:3px solid rgba(246,242,231,0.5);
    margin-bottom:24px;
  }
  .hero-tag .big-stat{font-family:'Bricolage Grotesque',sans-serif;font-size:46px;font-weight:800;color:var(--citrus);}
  .hero-tag .stat-label{font-size:12.5px;color:rgba(246,242,231,0.7);margin-top:2px;margin-bottom:22px;font-family:'IBM Plex Mono',monospace;letter-spacing:.04em;}
  .hero-tag hr{border:none;border-top:1px solid rgba(246,242,231,0.18);margin:18px 0;}
  .mini-stats{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  .mini-stats div b{display:block;font-size:22px;font-family:'Bricolage Grotesque',sans-serif;color:var(--paper);}
  .mini-stats div span{font-size:11.5px;color:rgba(246,242,231,0.65);}

  /* ---- Section heading pattern ---- */
  .sec-head{margin-bottom:42px;}
  .sec-head h2{font-size:34px;margin-top:14px;}
  .sec-head p{color:var(--muted);max-width:560px;margin-top:10px;font-size:15px;}

  /* ---- Why hire me ---- */
  .why-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;}
  @media(max-width:700px){.why-grid{grid-template-columns:1fr;}}
  .why-card{
    background:var(--paper2);border:1px solid var(--line);border-radius:16px;padding:26px;
    transition:transform .25s, border-color .25s;
  }
  .why-card:hover{transform:translateY(-2px);border-color:var(--citrus);}
  .why-card .num{font-family:'IBM Plex Mono',monospace;color:var(--citrus);font-weight:600;font-size:13px;}
  .why-card h3{font-size:18px;margin-top:10px;}
  .why-card p{font-size:14.5px;color:var(--muted);margin-top:8px;}

  /* ---- Strengths cards ---- */
  .strength-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
  @media(max-width:880px){.strength-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:560px){.strength-grid{grid-template-columns:1fr;}}
  .strength-card{
    background:#fff;border:1px solid var(--line);border-radius:14px;padding:22px;
  }
  .strength-card .icon{
    width:38px;height:38px;border-radius:10px;background:var(--leaf);
    display:flex;align-items:center;justify-content:center;color:#fff;font-size:17px;margin-bottom:14px;
  }
  .strength-card h4{font-size:15.5px;font-family:'Bricolage Grotesque',sans-serif;color:var(--ink);}
  .strength-card p{font-size:13.5px;color:var(--muted);margin-top:6px;}

  /* ---- Summary ---- */
  .summary-box{
    background:var(--ink); color:var(--paper);
    border-radius:18px; padding:40px;
    font-family:'Bricolage Grotesque',sans-serif;
    font-size:21px; line-height:1.5; font-weight:500;
  }
  @media(max-width:640px){.summary-box{font-size:17px;padding:26px;}}
  .summary-box .hl{color:var(--citrus);}

  /* ---- Skills dashboard ---- */
  .dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;}
  @media(max-width:800px){.dash-grid{grid-template-columns:1fr;gap:30px;}}
  .meter{margin-bottom:20px;}
  .meter-top{display:flex;justify-content:space-between;font-size:13.5px;font-weight:600;margin-bottom:7px;}
  .meter-top .pct{font-family:'IBM Plex Mono',monospace;color:var(--citrus);}
  .meter-track{height:9px;background:var(--line);border-radius:6px;overflow:hidden;}
  .meter-fill{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--leaf),var(--citrus));width:0;transition:width .9s ease;}
  .dash-sub{font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:18px;}

  /* ---- Timeline (experience) ---- */
  .timeline{position:relative;padding-left:30px;border-left:2px solid var(--line);}
  .tl-item{position:relative;margin-bottom:44px;}
  .tl-item:last-child{margin-bottom:0;}
  .tl-item::before{
    content:'';position:absolute;left:-37px;top:4px;
    width:14px;height:14px;border-radius:50%;
    background:var(--citrus);border:3px solid var(--paper);
  }
  .tl-date{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--leaf);font-weight:600;letter-spacing:.04em;}
  .tl-item h3{font-size:19px;margin-top:6px;}
  .tl-item .org{font-size:14px;color:var(--muted);font-weight:600;margin-top:2px;}
  .tl-item ul{margin:14px 0 0;padding-left:18px;}
  .tl-item li{font-size:14.5px;margin-bottom:7px;color:var(--charcoal);}
  .tl-item li b{color:var(--ink);}

  /* ---- Projects ---- */
  .proj-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  @media(max-width:760px){.proj-grid{grid-template-columns:1fr;}}
  .proj-card{
    border:1px solid var(--line); border-radius:16px; padding:26px;
    background:var(--paper2);
  }
  .proj-card .tag{margin-bottom:14px;}
  .proj-card h3{font-size:17.5px;}
  .proj-card p{font-size:14px;color:var(--muted);margin-top:8px;}

  .ach-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:30px;}

  /* ---- Featured work ---- */
  .work-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:18px;}
  @media(max-width:600px){.work-grid{grid-template-columns:1fr;}}
  .work-card{
    display:block;border:1px solid var(--line);border-radius:16px;padding:24px;
    background:var(--paper2); transition:transform .25s, border-color .25s, box-shadow .25s;
  }
  .work-card:hover{transform:translateY(-3px);border-color:var(--ink);box-shadow:0 10px 24px rgba(31,42,30,0.1);}
  .work-card .icon{
    width:38px;height:38px;border-radius:10px;background:var(--ink);
    display:flex;align-items:center;justify-content:center;color:var(--paper);font-size:16px;margin-bottom:16px;
  }
  .work-card h3{font-size:17px;}
  .work-card p{font-size:13.5px;color:var(--muted);margin-top:8px;}
  .work-card .visit{
    display:inline-flex;align-items:center;gap:6px;margin-top:16px;
    font-family:'IBM Plex Mono',monospace;font-size:11.5px;font-weight:600;
    color:var(--citrus);text-transform:uppercase;letter-spacing:.04em;
  }
  .ach-chip{
    background:#fff;border:1px solid var(--line);border-radius:30px;
    padding:9px 16px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;
  }
  .ach-chip .dot{width:6px;height:6px;border-radius:50%;background:var(--gold);}

  /* ---- Education ---- */
  .edu-table{width:100%;border-collapse:collapse;margin-top:10px;}
  .edu-table th{
    text-align:left;font-family:'IBM Plex Mono',monospace;font-size:11.5px;text-transform:uppercase;
    letter-spacing:.05em;color:var(--muted);padding:10px 14px;border-bottom:1px solid var(--line);
  }
  .edu-table td{padding:16px 14px;border-bottom:1px solid var(--line);font-size:14.5px;}
  .edu-table td.deg{font-weight:700;color:var(--ink);font-family:'Bricolage Grotesque',sans-serif;font-size:16px;}
  .edu-table td.score{font-family:'IBM Plex Mono',monospace;color:var(--citrus);font-weight:600;}
  @media(max-width:640px){
    .edu-table thead{display:none;}
    .edu-table tr{display:block;border-bottom:2px solid var(--line);padding:14px 0;}
    .edu-table td{display:flex;justify-content:space-between;border:none;padding:5px 0;}
    .edu-table td::before{content:attr(data-label);font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);}
  }

  /* ---- Certs ---- */
  .cert-row{display:flex;gap:16px;flex-wrap:wrap;}
  .cert-badge{
    display:flex;align-items:center;gap:12px;
    background:#fff;border:1px solid var(--line);border-radius:14px;padding:16px 20px;flex:1;min-width:240px;
  }
  .cert-badge .yr{
    font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:700;color:#fff;
    background:var(--leaf);border-radius:8px;padding:6px 9px;
  }
  .cert-badge h4{font-size:14px;font-family:'Bricolage Grotesque',sans-serif;color:var(--ink);}
  .cert-badge p{font-size:12.5px;color:var(--muted);margin-top:2px;}

  /* ---- Leadership ---- */
  .lead-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;}
  @media(max-width:700px){.lead-grid{grid-template-columns:1fr;}}
  .lead-card{border:1px solid var(--line);border-radius:14px;padding:22px;background:var(--paper2);}
  .lead-card h4{font-size:15.5px;font-family:'Bricolage Grotesque',sans-serif;}
  .lead-card p{font-size:13.5px;color:var(--muted);margin-top:6px;}

  /* ---- Tools ---- */
  .tools-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
  @media(max-width:700px){.tools-grid{grid-template-columns:repeat(2,1fr);}}
  .tool-pill{
    background:#fff;border:1px solid var(--line);border-radius:12px;padding:16px;text-align:center;
    font-size:13.5px;font-weight:600;
  }
  .tool-pill .cat{display:block;font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:var(--leaf);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;}

  /* ---- Career goals ---- */
  .goals-box{
    border:2px dashed var(--leaf); border-radius:18px;padding:36px;background:rgba(92,122,61,0.06);
  }
  .goals-box p{font-size:16.5px;color:var(--charcoal);}
  .goals-box p + p{margin-top:14px;}

  /* ---- Contact ---- */
  .contact-section{background:var(--ink);color:var(--paper);border-radius:24px;margin:0 auto;padding:60px 40px;}
  @media(max-width:640px){.contact-section{padding:40px 22px;}}
  .contact-section h2{color:var(--paper);font-size:32px;}
  .contact-section p.lead{color:rgba(246,242,231,0.7);margin-top:10px;}
  .contact-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:34px;}
  @media(max-width:760px){.contact-grid{grid-template-columns:repeat(2,1fr);}}
  .contact-pill{
    background:rgba(246,242,231,0.07);border:1px solid rgba(246,242,231,0.18);
    border-radius:14px;padding:18px;text-align:center;transition:background .2s, transform .2s;
  }
  .contact-pill:hover{background:var(--citrus);transform:translateY(-1px);border-color:var(--citrus);}
  .contact-pill .ic{font-size:20px;display:block;margin-bottom:8px;}
  .contact-pill .lbl{font-family:'IBM Plex Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:.05em;opacity:.65;}
  .contact-pill .val{font-size:13px;font-weight:600;margin-top:4px;word-break:break-word;}

  footer{text-align:center;padding:34px 0;color:var(--muted);font-size:12.5px;font-family:'IBM Plex Mono',monospace;}

  .reveal{opacity:0;transform:translateY(8px);transition:opacity .5s ease, transform .5s ease;}
  .reveal.in{opacity:1;transform:translateY(0);}
  @media (prefers-reduced-motion: reduce){
    .reveal{opacity:1;transform:none;transition:none;}
    .meter-fill{transition:none;}
  }
</style>
</head>
<body>

<nav>
  <div class="wrap navrow">
    <div class="name">Sumedha More</div>
    <div class="navlinks">
      <a href="#why">Why Me</a>
